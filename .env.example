# Flask Configuration
FLASK_DEBUG=1

# Hugging Face (optional, for faster model downloads)
HF_TOKEN=your_huggingface_token_here

# LLM Configuration: Choose provider (groq, gemini, or ollama)
USE_LLM=true
LLM_PROVIDER=groq

# Groq Configuration (recommended - free, ultra-fast, OpenAI-compatible)
# Get API key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=mixtral-8x7b-32768

# Google Gemini Configuration (alternative - free, but slower API)
# Get API key: https://ai.google.dev
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama Configuration (local, requires ollama service running)
# ollama serve
# ollama pull qwen2.5:14b-instruct
OLLAMA_MODEL=qwen2.5:14b-instruct
OLLAMA_CHAT_URL=http://localhost:11434/api/chat
OLLAMA_TAGS_URL=http://localhost:11434/api/tags
LLM_TIMEOUT_SECONDS=45

# LLM Sampling Parameters
LLM_TEMPERATURE=0.5
LLM_TOP_P=0.9

# Response Style (concise, balanced, or therapeutic)
RESPONSE_STYLE=balanced
